<file path="ui/css/style.css">
/* === Atlas UI — Clean and Calm === */

:root {
  --bg: #0f1117;
  --bg-surface: #161922;
  --bg-elevated: #1c2030;
  --bg-hover: #232838;
  --border: #2a2f3e;
  --text: #f0f2f5;
  --text-secondary: #a0a4b4;
  --text-muted: #6e7280;
  --accent: #6c8cff;
  --accent-dim: #4a6ad4;
  --success: #4ade80;
  --warning: #fbbf24;
  --danger: #f87171;
  --danger-dim: #dc2626;
  --font: 'Segoe UI', -apple-system, system-ui, sans-serif;
  --font-mono: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
  --radius: 8px;
  --radius-sm: 4px;
  --sidebar-width: 220px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  height: 100vh;
  overflow: hidden;
  display: flex;
  font-size: 16px;
  line-height: 1.5;
}

/* === Sidebar === */

.sidebar {
  width: var(--sidebar-width);
  background: var(--bg-surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  height: 100vh;
}

.sidebar-brand {
  padding: 20px 16px 16px;
  font-size: 18px;
  font-weight: 600;
  letter-spacing: 2px;
  color: var(--accent);
  border-bottom: 1px solid var(--border);
}

.sidebar-nav {
  flex: 1;
  padding: 8px 0;
  overflow-y: auto;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.15s;
  font-size: 15px;
  border-left: 3px solid transparent;
}

.nav-item:hover {
  background: var(--bg-hover);
  color: var(--text);
}

.nav-item.active {
  background: var(--bg-elevated);
  color: var(--accent);
  border-left-color: var(--accent);
}

.nav-item .nav-icon {
  width: 18px;
  text-align: center;
  font-size: 16px;
}

.nav-item .badge {
  margin-left: auto;
  background: var(--danger-dim);
  color: white;
  font-size: 12px;
  padding: 1px 6px;
  border-radius: 10px;
  font-weight: 600;
}

.badge {
  font-size: 12px;
}

.nav-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted);
  cursor: pointer;
  margin-top: 4px;
  border-top: 1px solid var(--border);
}

.nav-section-header:hover { color: var(--text-secondary); }

.nav-section-arrow {
  font-size: 10px;
  transition: transform 0.2s;
}

.nav-section-arrow.collapsed {
  transform: rotate(-90deg);
}

.nav-section-items.collapsed {
  display: none;
}

.nav-source-status {
  margin-left: auto;
  font-size: 12px;
  color: var(--text-muted);
}

.nav-source-status.active { color: var(--success); }

.sidebar-footer {
  padding: 12px 16px;
  border-top: 1px solid var(--border);
  font-size: 12px;
  color: var(--text-muted);
}

/* === Main Content === */

.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.screen {
  display: none;
  flex: 1;
  overflow-y: auto;
  padding: 24px 32px;
}

.screen.active {
  display: flex;
  flex-direction: column;
}

.screen-header {
  margin-bottom: 24px;
  flex-shrink: 0;
}

.screen-header h1 {
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 4px;
}

.screen-header p {
  color: var(--text-secondary);
  font-size: 15px;
  max-width: 640px;
  line-height: 1.5;
}

/* === Cards === */

.card {
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 12px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.card-title {
  font-size: 16px;
  font-weight: 600;
}

.card-meta {
  font-size: 13px;
  color: var(--text-secondary);
}

.card-body {
  font-size: 15px;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* === Buttons === */

.btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 18px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-elevated);
  color: var(--text);
  font-size: 15px;
  cursor: pointer;
  transition: all 0.15s;
  font-family: var(--font);
}

.btn:hover { background: var(--bg-hover); }
.btn:disabled { opacity: 0.5; cursor: not-allowed; }

.btn-primary {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
}

.btn-primary:hover { background: var(--accent-dim); }

.btn-danger {
  border-color: var(--danger-dim);
  color: var(--danger);
}

.btn-danger:hover { background: rgba(248, 113, 113, 0.1); }

.btn-sm { padding: 6px 12px; font-size: 13px; }

.btn-group { display: flex; gap: 8px; }

/* === Tags / Badges === */

.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 500;
}

.tag-primary { background: rgba(108, 140, 255, 0.15); color: var(--accent); }
.tag-secondary { background: rgba(139, 144, 160, 0.15); color: var(--text-secondary); }
.tag-success { background: rgba(74, 222, 128, 0.15); color: var(--success); }
.tag-warning { background: rgba(251, 191, 36, 0.15); color: var(--warning); }
.tag-danger { background: rgba(248, 113, 113, 0.15); color: var(--danger); }

/* === Tables / Lists === */

.list-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  transition: background 0.1s;
}

.list-item:hover { background: var(--bg-hover); }
.list-item:last-child { border-bottom: none; }

.list-item .item-main { flex: 1; }
.list-item .item-title { font-size: 15px; font-weight: 500; }
.list-item .item-subtitle { font-size: 14px; color: var(--text-secondary); }

/* === Chat === */

.chat-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 16px 0;
}

.chat-message {
  padding: 8px 0;
  margin-bottom: 8px;
}

.chat-message .msg-role {
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}

.chat-message.user .msg-role { color: var(--text-secondary); }
.chat-message.atlas .msg-role { color: var(--accent); }

.chat-message .msg-content {
  font-size: 15px;
  line-height: 1.65;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.chat-message .msg-content strong { color: var(--text); font-weight: 600; }

.chat-marker {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 8px;
  background: rgba(108, 140, 255, 0.1);
  border-radius: 4px;
  font-size: 13px;
  color: var(--accent);
  margin: 4px 0;
}

.chat-input-bar {
  display: flex;
  gap: 8px;
  padding: 16px 0;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}

.chat-input {
  flex: 1;
  padding: 10px 14px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-elevated);
  color: var(--text);
  font-size: 15px;
  font-family: var(--font);
  resize: none;
  outline: none;
}

.chat-input:focus { border-color: var(--accent); }

/* === Forms === */

.form-group { margin-bottom: 16px; }

.form-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 6px;
}

.form-input, .form-select, .form-textarea {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg-elevated);
  color: var(--text);
  font-size: 15px;
  font-family: var(--font);
  outline: none;
}

.form-input:focus, .form-select:focus, .form-textarea:focus {
  border-color: var(--accent);
}

.form-textarea {
  min-height: 100px;
  resize: vertical;
  font-family: var(--font-mono);
  font-size: 14px;
  line-height: 1.5;
}

select.form-select {
  appearance: none;
  cursor: pointer;
}

/* === Grid === */

.grid { display: grid; gap: 12px; }
.grid-2 { grid-template-columns: 1fr 1fr; }
.grid-3 { grid-template-columns: 1fr 1fr 1fr; }

/* === Stat Cards === */

.stat-card {
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  text-align: center;
}

.stat-card .stat-value {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 4px;
}

.stat-card .stat-label {
  font-size: 12px;
  color: var(--text-secondary);
}

/* === Typing indicator === */

.typing-indicator {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 0;
}

.typing-indicator span {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--text-muted);
  animation: typingPulse 1.4s ease-in-out infinite;
}

.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingPulse {
  0%, 60%, 100% { opacity: 0.3; transform: scale(0.8); }
  30% { opacity: 1; transform: scale(1); }
}

/* === Message timestamps === */

.msg-time {
  font-size: 12px;
  color: var(--text-muted);
  margin-left: 8px;
  font-weight: 400;
  letter-spacing: 0;
  text-transform: none;
}

/* === Message grouping === */

.chat-message.grouped {
  padding-top: 2px;
  margin-bottom: 2px;
}

.chat-message.grouped .msg-role { display: none; }

/* === Brief / Markdown content === */

.brief-content, .md-content {
  font-size: 15px;
  line-height: 1.7;
  word-wrap: break-word;
}

.brief-content h1, .md-content h1,
.brief-content h2, .md-content h2,
.brief-content h3, .md-content h3 {
  color: var(--text);
  margin: 16px 0 8px 0;
  line-height: 1.3;
}

.brief-content h1, .md-content h1 { font-size: 18px; }
.brief-content h2, .md-content h2 { font-size: 16px; }
.brief-content h3, .md-content h3 { font-size: 14px; }

.brief-content ul, .md-content ul,
.brief-content ol, .md-content ol {
  margin: 8px 0;
  padding-left: 20px;
}

.brief-content li, .md-content li {
  margin-bottom: 4px;
}

.brief-content code, .md-content code {
  background: var(--bg-elevated);
  padding: 1px 5px;
  border-radius: 3px;
  font-family: var(--font-mono);
  font-size: 12px;
}

.brief-content a, .md-content a {
  color: var(--accent);
  text-decoration: none;
}

.brief-content a:hover, .md-content a:hover {
  text-decoration: underline;
}

.brief-content strong, .md-content strong { color: var(--text); font-weight: 600; }
.brief-content em, .md-content em { color: var(--text-secondary); }

/* Brief section emphasis */
.brief-content h2:first-of-type,
.brief-content h3:first-of-type {
  margin-top: 8px;
}

.brief-actions {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}

/* === Conversation panel (goal interview / context interview) === */

.conversation-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.conversation-panel .chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 16px 0;
}

.conversation-panel .chat-input-bar {
  display: flex;
  gap: 8px;
  padding: 16px 0;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}

/* === Empty state === */

.empty-state {
  text-align: center;
  padding: 48px 24px;
  color: var(--text-muted);
}

.empty-state .empty-icon {
  font-size: 36px;
  margin-bottom: 12px;
}

.empty-state p { font-size: 14px; }

/* === Loading === */

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 24px;
  color: var(--text-secondary);
  font-size: 13px;
}

.spinner {
  width: 16px;
  height: 16px;
  border: 2px solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* === Scrollbar === */

::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

/* === Overdue highlight === */

.overdue { color: var(--danger) !important; }

/* === Tabs === */

.tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--border);
  margin-bottom: 16px;
}

.tab {
  padding: 8px 16px;
  font-size: 14px;
  color: var(--text-secondary);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
}

.tab:hover { color: var(--text); }
.tab.active { color: var(--accent); border-bottom-color: var(--accent); }

/* === Modal === */

.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  align-items: center;
  justify-content: center;
}

.modal-overlay.active { display: flex; }

.modal {
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  width: 90%;
  max-width: 560px;
  max-height: 80vh;
  overflow-y: auto;
  padding: 24px;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 16px;
}

.goal-status-copy {
  margin-top: 8px;
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}

.modal-actions {
