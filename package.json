{
  "name": "atlas",
  "version": "2.0.0",
  "description": "Atlas — Strategic Adviser",
  "main": "electron/main.js",
  "scripts": {
    "start": "node --no-deprecation src/index.js",
    "interview": "node src/index.js --interview",
    "brief": "node src/index.js --brief",
    "app": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.atlas.adviser",
    "productName": "Atlas",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "files": [
      "electron/**/*",
      "ui/**/*",
      "src/**/*",
      "config/**/*",
      "package.json",
      ".env"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": [
          "**/*",
          "!credentials/**"
        ]
      }
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "p-limit": "^7.3.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "whisper-cpp-node": "^0.2.12"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
