  flex-shrink: 0;
}

.health-dot.ok { background: var(--success); }
.health-dot.err { background: var(--danger); }
.health-dot.warn { background: var(--warning); }

/* === Guide === */

#screen-guide {
  position: relative;
}

.guide-search-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  gap: 8px;
